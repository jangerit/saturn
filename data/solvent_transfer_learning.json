{
    "running_mode": "distribution_learning",
    "device": "cuda",
    "seed": 42,
    "model_architecture": "mamba",
    "logging": {
        "logging_path": "data/solvent_prior_training.log",
        "model_checkpoints_dir": "data/solvent_prior_checkpoints/"
    },
    "distribution_learning": {
        "parameters": {
            "agent": "experimental_reproduction/checkpoint_models/zinc-250k-mamba-epoch-50.prior",
